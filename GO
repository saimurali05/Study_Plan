          { day: 365, task: "YEAR 1 COMPLETE. You're a builder, earner, and founder. The real game just started.", tag: "🎯" },
        ],
      },
    ],
  },
];

const tags = {
  Setup: "#64748b", Python: "#3b82f6", Build: "#10b981", Refactor: "#8b5cf6",
  Ship: "#f59e0b", API: "#06b6d4", Data: "#84cc16", Viz: "#ec4899",
  ML: "#f97316", AI: "#a78bfa", LangChain: "#60a5fa", Scraping: "#94a3b8",
  Automation: "#34d399", Backend: "#4ade80", Deploy: "#fb923c", Testing: "#f43f5e",
  "🎯": "#facc15", React: "#61dafb", CSS: "#7dd3fc", "Next.js": "#e5e7eb",
  Supabase: "#3ecf8e", Auth: "#f87171", "Real-time": "#c084fc", Storage: "#fbbf24",
  Serverless: "#a3e635", "Full-stack": "#67e8f9", Plan: "#e879f9", Monetize: "#4ade80",
  Frontend: "#93c5fd", Payments: "#6ee7b7", Launch: "#fde047", DevOps: "#f9a8d4",
  "CI/CD": "#a5b4fc", Security: "#fca5a5", Cache: "#86efac", Network: "#c4b5fd",
  TypeScript: "#2563eb", Database: "#0891b2", Portfolio: "#d946ef", Content: "#10b981",
  GitHub: "#e2e8f0", LinkedIn: "#0ea5e9", Exposure: "#fbbf24", Strategy: "#f97316",
  Service: "#34d399", LeadGen: "#a78bfa", Client: "#fb923c", Systems: "#60a5fa",
  Pricing: "#4ade80", Passive: "#facc15", Validate: "#f472b6", Milestone: "#fde047",
  "Lock-in": "#f43f5e", Beta: "#c084fc", SEO: "#34d399", Growth: "#fb923c",
  Partnerships: "#60a5fa", Retention: "#f43f5e", Product: "#a78bfa", Revenue: "#4ade80",
  Expand: "#fde047", Global: "#06b6d4", Funding: "#f97316", Finance: "#84cc16",
  Vision: "#e879f9", Reflect: "#94a3b8", Team: "#67e8f9", Rebuild: "#f87171",
  Outreach: "#fbbf24", Platform: "#c084fc", Delegate: "#34d399",
};

export default function FounderRoadmap() {
  const [activePhase, setActivePhase] = useState(0);
  const [expandedWeek, setExpandedWeek] = useState(null);
  const [completedDays, setCompletedDays] = useState({});
  const [mounted, setMounted] = useState(false);

  useEffect(() => {
    setMounted(true);
    const saved = localStorage.getItem("roadmap_completed");
    if (saved) setCompletedDays(JSON.parse(saved));
  }, []);

  const toggleDay = (day) => {
    const updated = { ...completedDays, [day]: !completedDays[day] };
    setCompletedDays(updated);
    localStorage.setItem("roadmap_completed", JSON.stringify(updated));
  };

  const totalDays = 365;
  const doneCount = Object.values(completedDays).filter(Boolean).length;
  const progress = Math.round((doneCount / totalDays) * 100);

  const phase = phases[activePhase];

  return (
    <div style={{ fontFamily: "'Courier New', monospace", background: "#0a0a0a", minHeight: "100vh", color: "#e2e8f0" }}>
      {/* Header */}
      <div style={{ background: "linear-gradient(135deg, #0a0a0a 0%, #111 100%)", borderBottom: "1px solid #1e293b", padding: "24px 20px 0" }}>
        <div style={{ maxWidth: 900, margin: "0 auto" }}>
          <div style={{ display: "flex", alignItems: "baseline", gap: 12, marginBottom: 4 }}>
            <h1 style={{ fontSize: 22, fontWeight: 900, color: "#f8fafc", letterSpacing: "-0.5px", margin: 0 }}>365-DAY FOUNDER ROADMAP</h1>
            <span style={{ fontSize: 11, color: "#64748b", letterSpacing: "2px", textTransform: "uppercase" }}>CSE → Crore</span>
          </div>
          <p style={{ fontSize: 12, color: "#475569", margin: "0 0 20px", letterSpacing: "1px" }}>Every. Single. Day. Intentional.</p>

          {/* Progress bar */}
          <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
            <div style={{ flex: 1, height: 4, background: "#1e293b", borderRadius: 2, overflow: "hidden" }}>
              <div style={{ height: "100%", width: `${progress}%`, background: "linear-gradient(90deg, #00ff88, #60a5fa, #a78bfa)", transition: "width 0.3s", borderRadius: 2 }} />
            </div>
            <span style={{ fontSize: 11, color: "#64748b", minWidth: 70 }}>{doneCount}/{totalDays} days</span>
          </div>

          {/* Phase tabs */}
          <div style={{ display: "flex", gap: 2, overflowX: "auto", paddingBottom: 1 }}>
            {phases.map((p, i) => (
              <button
                key={p.id}
                onClick={() => { setActivePhase(i); setExpandedWeek(null); }}
                style={{
                  background: activePhase === i ? p.color : "transparent",
                  color: activePhase === i ? "#0a0a0a" : "#475569",
                  border: `1px solid ${activePhase === i ? p.color : "#1e293b"}`,
                  padding: "8px 14px",
                  fontSize: 11,
                  fontWeight: 700,
                  cursor: "pointer",
                  borderRadius: "4px 4px 0 0",
                  whiteSpace: "nowrap",
                  transition: "all 0.15s",
                  letterSpacing: "0.5px",
                  fontFamily: "'Courier New', monospace",
                }}
              >
                {p.icon} P{p.id} · {p.name}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Phase content */}
      <div style={{ maxWidth: 900, margin: "0 auto", padding: "24px 20px" }}>
        {/* Phase header */}
        <div style={{
          background: `linear-gradient(135deg, ${phase.accent}88, #0f172a)`,
          border: `1px solid ${phase.color}33`,
          borderRadius: 8,
          padding: "20px 24px",
          marginBottom: 20,
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          flexWrap: "wrap",
          gap: 12,
        }}>
          <div>
            <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 6 }}>
              <span style={{ fontSize: 24 }}>{phase.icon}</span>
              <span style={{ fontSize: 18, fontWeight: 900, color: phase.color, letterSpacing: "-0.5px" }}>Phase {phase.id} — {phase.name}</span>
            </div>
            <p style={{ margin: 0, fontSize: 13, color: "#94a3b8" }}>{phase.tagline}</p>
          </div>
          <div style={{ textAlign: "right" }}>
            <div style={{ fontSize: 28, fontWeight: 900, color: phase.color, letterSpacing: "-1px" }}>Days {phase.days}</div>
          </div>
        </div>

        {/* Weeks */}
        <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
          {phase.weeks.map((week, wi) => {
            const weekKey = `${phase.id}-${wi}`;
            const isOpen = expandedWeek === weekKey;
            const weekDone = week.days.filter(d => completedDays[d.day]).length;

            return (
              <div key={wi} style={{ border: `1px solid ${isOpen ? phase.color + "44" : "#1e293b"}`, borderRadius: 6, overflow: "hidden", transition: "border-color 0.2s" }}>
                {/* Week header */}
                <button
                  onClick={() => setExpandedWeek(isOpen ? null : weekKey)}
                  style={{
                    width: "100%",
                    background: isOpen ? `${phase.accent}44` : "#111",
                    border: "none",
                    padding: "14px 18px",
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "space-between",
                    cursor: "pointer",
                    textAlign: "left",
                    transition: "background 0.2s",
                    gap: 12,
                  }}
                >
                  <div style={{ display: "flex", alignItems: "center", gap: 12, flex: 1 }}>
                    <span style={{ fontSize: 10, color: phase.color, fontWeight: 700, letterSpacing: "1px", minWidth: 60, fontFamily: "'Courier New', monospace" }}>
                      {typeof week.week === "number" ? `WK ${week.week}` : `WK ${week.week}`}
                    </span>
                    <span style={{ fontSize: 13, fontWeight: 700, color: "#e2e8f0", fontFamily: "'Courier New', monospace" }}>{week.title}</span>
                  </div>
                  <div style={{ display: "flex", alignItems: "center", gap: 10, flexShrink: 0 }}>
                    <span style={{ fontSize: 11, color: weekDone === week.days.length && weekDone > 0 ? phase.color : "#475569" }}>
                      {weekDone}/{week.days.length}
                    </span>
                    <span style={{ color: "#475569", fontSize: 14, transform: isOpen ? "rotate(180deg)" : "none", transition: "transform 0.2s" }}>▾</span>
                  </div>
                </button>

                {/* Days */}
                {isOpen && (
                  <div style={{ borderTop: `1px solid #1e293b` }}>
                    {week.days.map((d, di) => {
                      const done = completedDays[d.day];
                      return (
                        <div
                          key={di}
                          onClick={() => toggleDay(d.day)}
                          style={{
                            display: "flex",
                            alignItems: "flex-start",
                            gap: 12,
                            padding: "12px 18px",
                            borderBottom: di < week.days.length - 1 ? "1px solid #1e293b11" : "none",
                            cursor: "pointer",
                            background: done ? "#0f2" + "08" : "transparent",
                            transition: "background 0.15s",
                          }}
                        >
                          {/* Checkbox */}
                          <div style={{
                            width: 18, height: 18, borderRadius: 3, flexShrink: 0, marginTop: 1,
                            border: `1.5px solid ${done ? phase.color : "#334155"}`,
                            background: done ? phase.color : "transparent",
                            display: "flex", alignItems: "center", justifyContent: "center",
                            transition: "all 0.15s",
                          }}>
                            {done && <span style={{ fontSize: 10, color: "#0a0a0a", fontWeight: 900 }}>✓</span>}
                          </div>

                          {/* Day number */}
                          <span style={{ fontSize: 11, color: "#475569", minWidth: 48, fontFamily: "'Courier New', monospace", paddingTop: 1 }}>
                            DAY {d.day}
                          </span>

                          {/* Task */}
                          <span style={{ fontSize: 13, color: done ? "#475569" : "#cbd5e1", flex: 1, lineHeight: 1.5, textDecoration: done ? "line-through" : "none" }}>
                            {d.task}
                          </span>

                          {/* Tag */}
                          <span style={{
                            fontSize: 9, padding: "2px 7px", borderRadius: 3, flexShrink: 0,
                            background: (tags[d.tag] || "#475569") + "22",
                            color: tags[d.tag] || "#94a3b8",
                            border: `1px solid ${(tags[d.tag] || "#475569")}33`,
                            fontWeight: 700, letterSpacing: "0.5px", fontFamily: "'Courier New', monospace",
                            marginTop: 2,
                          }}>
                            {d.tag}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        {/* Bottom insight */}
        <div style={{ marginTop: 24, padding: "16px 20px", background: "#111", border: "1px solid #1e293b", borderRadius: 6 }}>
          <p style={{ margin: 0, fontSize: 12, color: "#64748b", lineHeight: 1.8 }}>
            <span style={{ color: "#f8fafc", fontWeight: 700 }}>The only rule:</span> a live URL beats a certificate every time. Click a day, build the thing, push it, share it. Repeat 365 times.
          </p>
        </div>
      </div>
    </div>
  );
}